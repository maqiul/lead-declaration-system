<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:xsd="http://www.w3.org/2001/XMLSchema" 
             xmlns:flowable="http://flowable.org/bpmn" 
             targetNamespace="http://www.flowable.org/processdef">
  <process id="declarationProcess" name="申报审批全生命周期流程(串行版)" isExecutable="true">
    <!-- 开始事件 -->
    <startEvent id="startEvent1" name="启动申报" flowable:initiator="starterId" />
    
    <!-- 生成预录入单服务任务 -->
    <serviceTask id="genPreEntryTask" name="生成预录入单" flowable:delegateExpression="${declarationServiceTask}" />
    
    <!-- 前置条件网关 -->
    <exclusiveGateway id="conditionGW" name="条件判断" />
    
    <!-- 部门初审 -->
    <userTask id="deptAudit" name="部门初审" flowable:candidateGroups="DEPT_MANAGER">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
        <flowable:taskListener event="complete" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 初审结果网关 -->
    <exclusiveGateway id="gw1" name="初审结果" />
    
    <!-- 驳回处理 -->
    <userTask id="rejectHandler" name="驳回修改" flowable:assignee="${starterId}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 生成合同 -->
    <serviceTask id="genContractTask" name="自动生成全套单证" flowable:delegateExpression="${declarationServiceTask}" />
    
    <!-- 串行流程开始 -->
    
    <!-- 定金上传 -->
    <userTask id="depositPayment" name="上传定金凭证" flowable:assignee="${starterId}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 定金审核 -->
    <userTask id="depositAudit" name="财务确认定金" flowable:candidateGroups="FINANCE_MANAGER">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
        <flowable:taskListener event="complete" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 定金审核结果网关 -->
    <exclusiveGateway id="gw2" name="定金审核结果" />
    
    <!-- 尾款上传 -->
    <userTask id="balancePayment" name="上传尾款凭证" flowable:assignee="${starterId}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 尾款审核 -->
    <userTask id="balanceAudit" name="财务确认尾款" flowable:candidateGroups="FINANCE_MANAGER">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
        <flowable:taskListener event="complete" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 尾款审核结果网关 -->
    <exclusiveGateway id="gw3" name="尾款审核结果" />
    
    <!-- 提货单上传 -->
    <userTask id="pickupListUpload" name="上传提货单" flowable:assignee="${starterId}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 提货单审核 -->
    <userTask id="pickupListAudit" name="财务确认提货单" flowable:candidateGroups="FINANCE_MANAGER">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${declarationTaskListener}" />
        <flowable:taskListener event="complete" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </userTask>
    
    <!-- 提货单审核结果网关 -->
    <exclusiveGateway id="gw4" name="提货单审核结果" />
    
    <!-- 结束事件 -->
    <endEvent id="endEvent1" name="流程完成">
      <extensionElements>
        <flowable:executionListener event="end" delegateExpression="${declarationTaskListener}" />
      </extensionElements>
    </endEvent>
    
    <!-- 流程连线定义 -->
    
    <!-- 启动流程 -->
    <sequenceFlow id="f1" sourceRef="startEvent1" targetRef="genPreEntryTask" />
    
    <!-- 生成预录入单到条件判断 -->
    <sequenceFlow id="f_preentry_to_condition" sourceRef="genPreEntryTask" targetRef="conditionGW" />
    
    <!-- 条件判断到部门初审 -->
    <sequenceFlow id="f_condition_to_audit" sourceRef="conditionGW" targetRef="deptAudit" />
    
    <!-- 初审到网关 -->
    <sequenceFlow id="f2" sourceRef="deptAudit" targetRef="gw1" />
    
    <!-- 初审通过 -->
    <sequenceFlow id="f3_pass" name="通过" sourceRef="gw1" targetRef="genContractTask">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>
    
    <!-- 初审驳回 -->
    <sequenceFlow id="f3_reject" name="驳回" sourceRef="gw1" targetRef="rejectHandler">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>
    
    <!-- 驳回后回到初审 -->
    <sequenceFlow id="f_reject_back" sourceRef="rejectHandler" targetRef="deptAudit" />
    
    <!-- 生成合同到定金上传 -->
    <sequenceFlow id="f4" sourceRef="genContractTask" targetRef="depositPayment" />
    
    <!-- 定金上传到审核 -->
    <sequenceFlow id="f_deposit_to_audit" sourceRef="depositPayment" targetRef="depositAudit" />
    
    <!-- 定金审核到网关 -->
    <sequenceFlow id="f_deposit_audit_result" sourceRef="depositAudit" targetRef="gw2" />
    
    <!-- 定金审核通过 -->
    <sequenceFlow id="f_deposit_pass" name="通过" sourceRef="gw2" targetRef="balancePayment">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>
    
    <!-- 定金审核驳回 -->
    <sequenceFlow id="f_deposit_reject" name="驳回" sourceRef="gw2" targetRef="depositPayment">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>
    
    <!-- 尾款上传到审核 -->
    <sequenceFlow id="f_balance_to_audit" sourceRef="balancePayment" targetRef="balanceAudit" />
    
    <!-- 尾款审核到网关 -->
    <sequenceFlow id="f_balance_audit_result" sourceRef="balanceAudit" targetRef="gw3" />
    
    <!-- 尾款审核通过 -->
    <sequenceFlow id="f_balance_pass" name="通过" sourceRef="gw3" targetRef="pickupListUpload">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>
    
    <!-- 尾款审核驳回 -->
    <sequenceFlow id="f_balance_reject" name="驳回" sourceRef="gw3" targetRef="balancePayment">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>
    
    <!-- 提货单上传到审核 -->
    <sequenceFlow id="f_pickup_to_audit" sourceRef="pickupListUpload" targetRef="pickupListAudit" />
    
    <!-- 提货单审核到网关 -->
    <sequenceFlow id="f_pickup_audit_result" sourceRef="pickupListAudit" targetRef="gw4" />
    
    <!-- 提货单审核通过 -->
    <sequenceFlow id="f_pickup_pass" name="通过" sourceRef="gw4" targetRef="endEvent1">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>
    
    <!-- 提货单审核驳回 -->
    <sequenceFlow id="f_pickup_reject" name="驳回" sourceRef="gw4" targetRef="pickupListUpload">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>
    
  </process>
  
  <!-- BPMN 图形定义 -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_declarationProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_declarationProcess" bpmnElement="declarationProcess">
      <!-- 形状定义 -->
      <bpmndi:BPMNShape id="BPMNShape_startEvent1" bpmnElement="startEvent1">
        <omgdc:Bounds x="50" y="200" width="30" height="30" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_genPreEntryTask" bpmnElement="genPreEntryTask">
        <omgdc:Bounds x="90" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_conditionGW" bpmnElement="conditionGW" isMarkerVisible="true">
        <omgdc:Bounds x="230" y="200" width="40" height="40" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_deptAudit" bpmnElement="deptAudit">
        <omgdc:Bounds x="300" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_gw1" bpmnElement="gw1" isMarkerVisible="true">
        <omgdc:Bounds x="440" y="200" width="40" height="40" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_rejectHandler" bpmnElement="rejectHandler">
        <omgdc:Bounds x="300" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_genContractTask" bpmnElement="genContractTask">
        <omgdc:Bounds x="520" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_depositPayment" bpmnElement="depositPayment">
        <omgdc:Bounds x="560" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_depositAudit" bpmnElement="depositAudit">
        <omgdc:Bounds x="700" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_gw2" bpmnElement="gw2" isMarkerVisible="true">
        <omgdc:Bounds x="840" y="200" width="40" height="40" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_balancePayment" bpmnElement="balancePayment">
        <omgdc:Bounds x="920" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_balanceAudit" bpmnElement="balanceAudit">
        <omgdc:Bounds x="1060" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_gw3" bpmnElement="gw3" isMarkerVisible="true">
        <omgdc:Bounds x="1200" y="200" width="40" height="40" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_pickupListUpload" bpmnElement="pickupListUpload">
        <omgdc:Bounds x="1280" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_pickupListAudit" bpmnElement="pickupListAudit">
        <omgdc:Bounds x="1420" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_gw4" bpmnElement="gw4" isMarkerVisible="true">
        <omgdc:Bounds x="1560" y="200" width="40" height="40" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BPMNShape_endEvent1" bpmnElement="endEvent1">
        <omgdc:Bounds x="1780" y="206" width="28" height="28" />
      </bpmndi:BPMNShape>
      
      <!-- 连线定义 -->
      <bpmndi:BPMNEdge id="BPMNEdge_f1" bpmnElement="f1">
        <omgdi:waypoint x="80" y="215" />
        <omgdi:waypoint x="90" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_preentry_to_condition" bpmnElement="f_preentry_to_condition">
        <omgdi:waypoint x="190" y="215" />
        <omgdi:waypoint x="230" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_condition_to_audit" bpmnElement="f_condition_to_audit">
        <omgdi:waypoint x="270" y="215" />
        <omgdi:waypoint x="300" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f2" bpmnElement="f2">
        <omgdi:waypoint x="400" y="215" />
        <omgdi:waypoint x="440" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f3_pass" bpmnElement="f3_pass">
        <omgdi:waypoint x="440" y="215" />
        <omgdi:waypoint x="520" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f3_reject" bpmnElement="f3_reject">
        <omgdi:waypoint x="460" y="200" />
        <omgdi:waypoint x="460" y="100" />
        <omgdi:waypoint x="400" y="100" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_reject_back" bpmnElement="f_reject_back">
        <omgdi:waypoint x="300" y="100" />
        <omgdi:waypoint x="280" y="100" />
        <omgdi:waypoint x="280" y="215" />
        <omgdi:waypoint x="300" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f4" bpmnElement="f4">
        <omgdi:waypoint x="520" y="215" />
        <omgdi:waypoint x="560" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_deposit_to_audit" bpmnElement="f_deposit_to_audit">
        <omgdi:waypoint x="660" y="215" />
        <omgdi:waypoint x="700" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_deposit_audit_result" bpmnElement="f_deposit_audit_result">
        <omgdi:waypoint x="800" y="215" />
        <omgdi:waypoint x="840" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_deposit_pass" bpmnElement="f_deposit_pass">
        <omgdi:waypoint x="880" y="215" />
        <omgdi:waypoint x="920" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_deposit_reject" bpmnElement="f_deposit_reject">
        <omgdi:waypoint x="860" y="200" />
        <omgdi:waypoint x="860" y="150" />
        <omgdi:waypoint x="610" y="150" />
        <omgdi:waypoint x="610" y="180" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_balance_to_audit" bpmnElement="f_balance_to_audit">
        <omgdi:waypoint x="1020" y="215" />
        <omgdi:waypoint x="1060" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_balance_audit_result" bpmnElement="f_balance_audit_result">
        <omgdi:waypoint x="1160" y="215" />
        <omgdi:waypoint x="1200" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_balance_pass" bpmnElement="f_balance_pass">
        <omgdi:waypoint x="1240" y="215" />
        <omgdi:waypoint x="1280" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_balance_reject" bpmnElement="f_balance_reject">
        <omgdi:waypoint x="1220" y="200" />
        <omgdi:waypoint x="1220" y="150" />
        <omgdi:waypoint x="970" y="150" />
        <omgdi:waypoint x="970" y="180" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_pickup_to_audit" bpmnElement="f_pickup_to_audit">
        <omgdi:waypoint x="1380" y="215" />
        <omgdi:waypoint x="1420" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_pickup_audit_result" bpmnElement="f_pickup_audit_result">
        <omgdi:waypoint x="1520" y="215" />
        <omgdi:waypoint x="1560" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_pickup_pass" bpmnElement="f_pickup_pass">
        <omgdi:waypoint x="1600" y="215" />
        <omgdi:waypoint x="1780" y="215" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="BPMNEdge_f_pickup_reject" bpmnElement="f_pickup_reject">
        <omgdi:waypoint x="1580" y="230" />
        <omgdi:waypoint x="1580" y="270" />
        <omgdi:waypoint x="1330" y="270" />
        <omgdi:waypoint x="1330" y="250" />
      </bpmndi:BPMNEdge>
      
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>