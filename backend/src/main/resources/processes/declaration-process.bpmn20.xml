        <omgdi:waypoint x="850.0" y="250.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f8" id="BPMNEdge_f8">
        <omgdi:waypoint x="780.0" y="230.0"></omgdi:waypoint>
        <omgdi:waypoint x="780.0" y="150.0"></omgdi:waypoint>
        <omgdi:waypoint x="540.0" y="150.0"></omgdi:waypoint>
        <omgdi:waypoint x="540.0" y="210.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f8_1" id="BPMNEdge_f8_1">
