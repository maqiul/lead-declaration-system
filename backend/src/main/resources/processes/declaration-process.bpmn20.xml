        <omgdi:waypoint x="170.0" y="120.0"></omgdi:waypoint>
        <omgdi:waypoint x="170.0" y="210.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f5" id="BPMNEdge_f5">
