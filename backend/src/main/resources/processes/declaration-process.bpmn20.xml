      <bpmndi:BPMNShape bpmnElement="gw1" id="BPMNShape_gw1">
        <omgdc:Bounds height="40.0" width="40.0" x="260.0" y="230.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="genContractTask" id="BPMNShape_genContractTask">
        <omgdc:Bounds height="80.0" width="100.0" x="350.0" y="210.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="depositPayment" id="BPMNShape_depositPayment">
