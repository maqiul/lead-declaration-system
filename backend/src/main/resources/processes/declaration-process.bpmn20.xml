      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw2" id="BPMNShape_gw2">
        <omgdc:Bounds height="40.0" width="40.0" x="760.0" y="230.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="balancePayment" id="BPMNShape_balancePayment">
        <omgdc:Bounds height="80.0" width="100.0" x="850.0" y="210.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="balanceAudit" id="BPMNShape_balanceAudit">
        <omgdc:Bounds height="80.0" width="100.0" x="990.0" y="210.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw3" id="BPMNShape_gw3">
        <omgdc:Bounds height="40.0" width="40.0" x="1130.0" y="230.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="pickupListUpload" id="BPMNShape_pickupListUpload">
        <omgdc:Bounds height="80.0" width="100.0" x="1220.0" y="210.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="pickupListAudit" id="BPMNShape_pickupListAudit">
        <omgdc:Bounds height="80.0" width="100.0" x="1360.0" y="210.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw4" id="BPMNShape_gw4">
        <omgdc:Bounds height="40.0" width="40.0" x="1500.0" y="230.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent1" id="BPMNShape_endEvent1">
        <omgdc:Bounds height="28.0" width="28.0" x="1580.0" y="236.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="rejectHandler" id="BPMNShape_rejectHandler">
        <omgdc:Bounds height="80.0" width="100.0" x="230.0" y="80.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>

      <!-- Connection Lines -->
      <bpmndi:BPMNEdge bpmnElement="f1" id="BPMNEdge_f1">
        <omgdi:waypoint x="80.0" y="250.0"></omgdi:waypoint>
        <omgdi:waypoint x="120.0" y="250.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f2" id="BPMNEdge_f2">
        <omgdi:waypoint x="220.0" y="250.0"></omgdi:waypoint>
        <omgdi:waypoint x="260.0" y="250.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f3" id="BPMNEdge_f3">
        <omgdi:waypoint x="300.0" y="250.0"></omgdi:waypoint>
        <omgdi:waypoint x="350.0" y="250.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f4" id="BPMNEdge_f4">
        <omgdi:waypoint x="280.0" y="230.0"></omgdi:waypoint>
        <omgdi:waypoint x="280.0" y="160.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f12" id="BPMNEdge_f12">
