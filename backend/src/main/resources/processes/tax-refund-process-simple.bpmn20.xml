  <process id="tax_refund_process_simple" name="税务退费审批流程(简化版)" isExecutable="true">
    
    <!-- 开始事件 -->
    <startEvent id="startEvent" name="开始" />
    
    <!-- 部门提交信息任务 -->
    <userTask id="departmentSubmit" name="部门提交信息" 
              flowable:assignee="${initiator}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${taxRefundExecutionListener}"></flowable:taskListener>
      </extensionElements>
    </userTask>
    
    <!-- 财务初审任务 -->
    <userTask id="financeReview" name="财务初审" 
              flowable:candidateGroups="finance">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${taxRefundExecutionListener}"></flowable:taskListener>
      </extensionElements>
    </userTask>
    
    <!-- 生成文件服务任务 -->
    <serviceTask id="generateDocument" name="生成财务文件" 
                 flowable:delegateExpression="${taxRefundServiceTask}"> </serviceTask>
    
    <!-- 财务复审任务 -->
    <userTask id="financeFinalReview" name="财务复审" 
              flowable:candidateGroups="finance">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${taxRefundExecutionListener}"></flowable:taskListener>
      </extensionElements>
    </userTask>
    
    <!-- 文件归档服务任务 -->
    <serviceTask id="archiveDocument" name="文件归档" 
                 flowable:delegateExpression="${taxRefundServiceTask}"> </serviceTask>
    
    <!-- 结束事件 -->
    <endEvent id="endEvent" name="结束" />
    
    <!-- 流程连线 -->
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="departmentSubmit" />
    <sequenceFlow id="flow2" sourceRef="departmentSubmit" targetRef="financeReview" />
    <sequenceFlow id="flow3" sourceRef="financeReview" targetRef="generateDocument" />
    <sequenceFlow id="flow4" sourceRef="generateDocument" targetRef="financeFinalReview" />
    <sequenceFlow id="flow5" sourceRef="financeFinalReview" targetRef="archiveDocument" />
    <sequenceFlow id="flow6" sourceRef="archiveDocument" targetRef="endEvent" />
    
  </process>
  
